# Start from the base image you pulled
FROM rockylinux/rockylinux:9.6

# Set a working directory inside the container
WORKDIR /opt/stalwart

# Copy the install script into the container
COPY install.sh .

# Run the installation script (ensure necessary build tools are installed first)
RUN dnf update -y && \
    dnf install -y curl git make gcc && \
    sh install.sh && \
    dnf clean all

# Expose the required ports
EXPOSE 443
EXPOSE 25
EXPOSE 110
EXPOSE 587
EXPOSE 465
EXPOSE 143
EXPOSE 993
EXPOSE 995
EXPOSE 4190
EXPOSE 8080

# You can also list them all on one line, separated by spaces:
# EXPOSE 443 25 110 587 465 143 993 995 4190 8080

